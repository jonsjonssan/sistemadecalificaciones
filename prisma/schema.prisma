generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  rol       String
  activo    Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gradosComoTutor   Grado          @relation("TutorGrado")
  materiasAsignadas DocenteMateria[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([rol, activo])
}

model Grado {
  id        String   @id @default(cuid())
  numero    Int
  seccion   String   @default("A")
  año       Int      @default(2026)
  docenteId String?
  activo    Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  docente     Usuario?       @relation("TutorGrado", fields: [docenteId], references: [id])
  estudiantes Estudiante[]
  materias    Materia[]
  asistencias Asistencia[]
  auditLogs   AuditLog[]

  @@unique([numero, seccion, año])
  @@index([docenteId])
  @@index([numero, activo])
}

model Estudiante {
  id        String   @id @default(cuid())
  numero    Int
  nombre    String
  gradoId   String
  activo    Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grado          Grado           @relation(fields: [gradoId], references: [id])
  calificaciones Calificacion[]
  calificacionesHistorico CalificacionHistorico[]
  asistencias    Asistencia[]
  auditLogs      AuditLog[]

  @@index([gradoId, activo])
  @@index([nombre])
  @@index([numero, gradoId])
}

model Materia {
  id        String   @id @default(cuid())
  nombre    String
  gradoId   String
  activa    Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grado             Grado               @relation(fields: [gradoId], references: [id])
  calificaciones    Calificacion[]
  configActividades ConfigActividad[]
  docentesAsignados DocenteMateria[]
  libertades        Asistencia[]
  auditLogs         AuditLog[]

  @@index([gradoId, activa])
  @@index([nombre])
}

model DocenteMateria {
  id        String   @id @default(cuid())
  docenteId String
  materiaId String
  createdAt DateTime @default(now())

  docente Usuario @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  materia Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@unique([docenteId, materiaId])
  @@index([docenteId])
  @@index([materiaId])
}

model ConfigActividad {
  id                         String   @id @default(cuid())
  materiaId                  String
  trimestre                  Int      @default(1)
  numActividadesCotidianas   Int      @default(4)
  numActividadesIntegradoras Int      @default(1)
  tieneExamen                Boolean  @default(true)
  porcentajeAC               Float    @default(35.0)
  porcentajeAI               Float    @default(35.0)
  porcentajeExamen           Float    @default(30.0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  materia Materia @relation(fields: [materiaId], references: [id])

  @@unique([materiaId, trimestre])
  @@index([materiaId])
}

model ConfiguracionSistema {
  id           String   @id @default(cuid())
  añoEscolar   Int      @default(2026)
  escuela      String   @default("Centro Escolar")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Calificacion {
  id           String   @id @default(cuid())
  estudianteId String
  materiaId    String
  trimestre    Int      @default(1)
  actividadesCotidianas   String?
  calificacionAC          Float?
  actividadesIntegradoras String?
  calificacionAI          Float?
  examenTrimestral        Float?
  promedioFinal           Float?
  recuperacion            Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
  materia    Materia    @relation(fields: [materiaId], references: [id])

  @@unique([estudianteId, materiaId, trimestre])
  @@index([estudianteId])
  @@index([materiaId])
  @@index([trimestre])
}

model CalificacionHistorico {
  id              String   @id @default(cuid())
  calificacionId  String
  version         Int
  estudianteId    String
  materiaId       String
  trimestre       Int
  actividadesCotidianas   String?
  calificacionAC          Float?
  actividadesIntegradoras String?
  calificacionAI          Float?
  examenTrimestral        Float?
  promedioFinal           Float?
  recuperacion            Float?
  modificadoPor          String
  motivoCambio           String?
  createdAt DateTime @default(now())

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])

  @@index([calificacionId])
  @@index([estudianteId])
}

model Asistencia {
  id           String   @id @default(cuid())
  estudianteId String
  fecha        DateTime
  estado       String
  gradoId      String?
  materiaId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  estudiante Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  grado      Grado?     @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  materia    Materia?  @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, fecha, gradoId, materiaId], name: "unica_asistencia_dia")
  @@index([estudianteId])
  @@index([fecha])
  @@index([estado])
  @@index([estudianteId, fecha])
}

model AuditLog {
  id          String   @id @default(cuid())
  accion      String
  entidad     String
  entidadId   String?
  usuarioId   String
  usuarioEmail String
  detalles    String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  usuario   Usuario?   @relation(fields: [usuarioId], references: [id])
  grado     Grado?     @relation(fields: [entidadId], references: [id], map: "audit_log_grado_fk")
  estudiante Estudiante? @relation(fields: [entidadId], references: [id], map: "audit_log_estudiante_fk")

  @@index([usuarioId])
  @@index([entidad])
  @@index([createdAt])
  @@index([accion, entidad])
  @@index([entidadId])
}
